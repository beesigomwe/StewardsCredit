# StewardsCredit Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
#
# For Apache: use SetEnv directives in your VirtualHost config.
# For Nginx:  use fastcgi_param directives in your server block.
# For CLI:    export these before running PHP scripts.

# Application Environment: "development" or "production"
CI_ENV=production

# Database Credentials
DB_HOSTNAME=localhost
DB_USERNAME=stewards
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_DATABASE=stewards

# Mail Configuration (used by Email_model)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=stewardscreditservices@gmail.com
MAIL_PASSWORD=YOUR_APP_PASSWORD_HERE
MAIL_LIBRARY=php
