ALTER TABLE `comments`
	CHANGE COLUMN `amount` `amount` DOUBLE(30,4) NULL DEFAULT NULL AFTER `currency`,
	CHANGE COLUMN `opening_balance` `opening_balance` DOUBLE(30,4) NULL DEFAULT NULL AFTER `amount`,
	CHANGE COLUMN `closing_balance` `closing_balance` DOUBLE(30,4) NULL DEFAULT NULL AFTER `opening_balance`;


ALTER TABLE `transaction`
	CHANGE COLUMN `amount` `amount` DOUBLE(30,4) NULL DEFAULT NULL AFTER `category`,
	CHANGE COLUMN `opening_balance` `opening_balance` DOUBLE(30,4) NULL DEFAULT NULL AFTER `note`,
	CHANGE COLUMN `dr` `dr` DOUBLE(30,4) NULL DEFAULT NULL AFTER `opening_balance`,
	CHANGE COLUMN `cr` `cr` DOUBLE(30,4) NULL DEFAULT NULL AFTER `dr`,
	CHANGE COLUMN `closing_balance` `closing_balance` DOUBLE(30,4) NULL DEFAULT NULL AFTER `cr`,
	CHANGE COLUMN `bal` `bal` DOUBLE(30,4) NULL DEFAULT NULL AFTER `closing_balance`;


ALTER TABLE `posts`
	CHANGE COLUMN `amount` `amount` DOUBLE(30,4) NULL DEFAULT NULL AFTER `user_id`,
	CHANGE COLUMN `balance` `balance` DOUBLE(30,4) NULL DEFAULT NULL AFTER `amount`;


