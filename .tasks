// SQL
ALTER TABLE `comments`
	CHANGE COLUMN `account` `account` INT(11) NULL DEFAULT NULL AFTER `closing_balance`,
	CHANGE COLUMN `comment` `comment` VARCHAR(5000) NULL DEFAULT NULL COLLATE 'utf8_general_ci' AFTER `post_type`,
	CHANGE COLUMN `user_id` `user_id` INT(11) NULL DEFAULT NULL AFTER `comment`,
	CHANGE COLUMN `email` `email` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8_general_ci' AFTER `name`,
	CHANGE COLUMN `last_modified` `last_modified` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP AFTER `created_at`,
	CHANGE COLUMN `parent_id` `parent_id` INT(11) NULL DEFAULT '0' AFTER `last_modified`,
	CHANGE COLUMN `uuid` `uuid` VARCHAR(50) NULL DEFAULT NULL COLLATE 'utf8_general_ci' AFTER `parent_id`,
	CHANGE COLUMN `comment` `comment` VARCHAR(5000) NULL DEFAULT NULL COLLATE 'utf8_general_ci' AFTER `trans_type`,
	CHANGE COLUMN `currency` `currency` VARCHAR(10) NULL DEFAULT NULL COLLATE 'utf8_general_ci' AFTER `trans_date`,
	CHANGE COLUMN `amount` `amount` BIGINT(50) NULL DEFAULT NULL AFTER `currency`,
	CHANGE COLUMN `opening_balance` `opening_balance` BIGINT(50) NULL DEFAULT '0' AFTER `amount`,
	CHANGE COLUMN `closing_balance` `closing_balance` BIGINT(50) NULL DEFAULT '0' AFTER `opening_balance`,
	CHANGE COLUMN `payment_method` `payment_method` INT(10) NULL DEFAULT NULL AFTER `closing_balance`;

ALTER TABLE `transaction`
	CHANGE COLUMN `opening_balance` `opening_balance` DOUBLE(22,0) NULL DEFAULT NULL AFTER `note`,
	CHANGE COLUMN `bal` `bal` DOUBLE(22,0) NULL DEFAULT NULL AFTER `closing_balance`;

ALTER TABLE `comments`
	ADD COLUMN `category` VARCHAR(10) NULL DEFAULT NULL AFTER `trans_type`,
	CHANGE COLUMN `category` `category` VARCHAR(30) NULL DEFAULT NULL COLLATE 'utf8_general_ci' AFTER `trans_type`;


